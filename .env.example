# Required
BOT_TOKEN=your_telegram_bot_token

# Model access (choose one mode)
# Direct OpenAI:
OPENAI_API_KEY=your_openai_api_key
# OpenAI-compatible proxy (for example local Bifrost).
# In this mode, you may leave OPENAI_API_KEY empty, for example:
# OPENAI_API_KEY=
OPENAI_BASE_URL=http://127.0.0.1:8080/openai/v1

# Optional: access control
BOT_WHITELIST=123456789,987654321
DEVELOPER_CHAT_ID=123456789

# Optional: model settings
OPENAI_MODEL=gpt-5-mini
OPENAI_TEMPERATURE=0.0
AGENT_MAX_CACHE_SIZE=50

# Optional: UX
MAX_MESSAGE_LENGTH=1000

# Optional: MCP and shutdown timeouts (seconds)
MCP_CONNECT_TIMEOUT=30
MCP_CLEANUP_TIMEOUT=10
MCP_SERVER_TIMEOUT=300
SHUTDOWN_TIMEOUT=20

# Optional: external integrations
FIRECRAWL_API_KEY=
SERPAPI_API_KEY=

# Optional: observability
LOGFIRE_TOKEN=
